<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/apps_drawer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#77000000"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/apps_drawer_dummy_input_anchor"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:visibility="invisible" />

    <LinearLayout
        android:id="@+id/apps_drawer_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/apps_drawer_dummy_input_anchor"
        android:orientation="vertical"
        android:layout_marginStart="28dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/apps_drawer_border"
        android:padding="2dp">

        <ListView
            android:id="@+id/apps_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:fastScrollEnabled="false"
            android:listSelector="@android:color/transparent"
            android:paddingStart="58dp"
            android:paddingTop="14dp"
            android:paddingEnd="42dp"
            android:paddingBottom="44dp"
            android:scrollbars="none" />

    </LinearLayout>

    <TextView
        android:id="@+id/apps_drawer_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/apps_drawer_container"
        android:layout_alignStart="@id/apps_drawer_container"
        android:layout_marginTop="-10dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/apps_drawer_header_border"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="Applications/ [s]"
        android:textColor="#A5D6A7"
        android:textSize="14sp"
        android:fontFamily="monospace" />

    <ScrollView
        android:id="@+id/apps_group_tabs_scroll"
        android:layout_width="42dp"
        android:layout_height="match_parent"
        android:layout_alignTop="@id/apps_drawer_container"
        android:layout_alignBottom="@id/apps_drawer_container"
        android:layout_alignStart="@id/apps_drawer_container"
        android:layout_marginStart="-10dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/apps_group_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/apps_alpha_tabs_scroll"
        android:layout_width="34dp"
        android:layout_height="match_parent"
        android:layout_alignTop="@id/apps_drawer_container"
        android:layout_alignBottom="@id/apps_drawer_container"
        android:layout_alignEnd="@id/apps_drawer_container"
        android:layout_marginEnd="-10dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/apps_alpha_tabs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical" />
    </LinearLayout>

    <TextView
        android:id="@+id/apps_drawer_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@id/apps_drawer_container"
        android:layout_alignEnd="@id/apps_drawer_container"
        android:layout_marginBottom="-10dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/apps_drawer_header_border"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="total 0 [~]"
        android:textColor="#A5D6A7"
        android:textSize="12sp"
        android:fontFamily="monospace" />

</RelativeLayout>
