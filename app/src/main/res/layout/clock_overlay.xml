<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clock_overlay_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <TextView
        android:id="@+id/timer_tab"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="6dp"
        android:background="@drawable/terminal_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="4dp"
        android:drawableTop="@drawable/timer_24"
        android:drawablePadding="2dp"
        android:text="--:--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/stopwatch_tab"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="6dp"
        android:background="@drawable/terminal_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="4dp"
        android:drawableTop="@drawable/hourglass_24"
        android:drawablePadding="2dp"
        android:text="--:--"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
